{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/5c572e77-1a4e-4518-b82d-617cad976e5f/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/api/jobs-trigger",
      "methods": ["POST"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/settings",
      "methods": ["PUT"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/sites-stale",
      "methods": ["POST"],
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/*",
      "methods": ["GET"],
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    },
    "403": {
      "statusCode": 403,
      "body": "Forbidden"
    }
  },
  "networking": {
    "allowedIpRanges": [
      "98.62.142.244/32",
      "8.31.229.4/32"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "X-XSS-Protection": "0",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Content-Security-Policy": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://login.microsoftonline.com",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=()",
    "Cache-Control": "no-store"
  }
}
